# Cloudflare D1
CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=
CF_API_TOKEN=

# Encryption
WALLET_ENCRYPTION_KEY=   # 32-byte hex string, generate with: openssl rand -hex 32

# Internal auth (shared secret with the API)
INTERNAL_API_KEY=        # generate with: openssl rand -hex 32

# Blockchain
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
FUJI_WSS_URL=wss://api.avax-test.network/ext/bc/C/ws

# Faucet
FAUCET_PRIVATE_KEY=      # without 0x prefix
FAUCET_THRESHOLD_AVAX=0.05
FAUCET_TOPUP_AMOUNT_AVAX=0.1

# Signing service wallet
SIGNER_PRIVATE_KEY=      # without 0x prefix

# Batch mint cron (every 5 min)
BATCH_MINT_CRON=*/5 * * * *